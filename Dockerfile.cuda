# BUILD_CUDA=1 (default): compiles llama-cpp-python with CUDA support — requires local GPU build.
# BUILD_CUDA=0: installs a CPU-only pre-built wheel; used by CI to validate image structure
#               without exhausting runner disk/memory on 400+ nvcc compilation units.
# BASE_IMAGE: override in CI (e.g. ubuntu:22.04) to avoid pulling the 3 GB CUDA image.
ARG BUILD_CUDA=1
ARG BASE_IMAGE=nvidia/cuda:12.4.1-devel-ubuntu22.04

FROM ${BASE_IMAGE}

ARG BUILD_CUDA

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /app

COPY pyproject.toml uv.lock ./

RUN if [ "$BUILD_CUDA" = "1" ]; then \
      CMAKE_ARGS="-DGGML_CUDA=ON" FORCE_CMAKE=1 \
        uv sync --extra llama-cpp --no-dev --frozen --no-install-project; \
    else \
      uv sync --extra llama-cpp --no-dev --frozen --no-install-project; \
    fi

COPY src/ ./src/
COPY README.md ./

RUN if [ "$BUILD_CUDA" = "1" ]; then \
      CMAKE_ARGS="-DGGML_CUDA=ON" FORCE_CMAKE=1 \
        uv sync --extra llama-cpp --no-dev --frozen; \
    else \
      uv sync --extra llama-cpp --no-dev --frozen; \
    fi

ENTRYPOINT ["/app/.venv/bin/llm-bench"]
CMD ["--help"]
